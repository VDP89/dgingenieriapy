---
import Base from '../layouts/Base.astro';
---

<Base title="Contacto">

  <!-- HERO -->
  <section class="bg-slate-dg text-cream py-16 md:py-28">
    <div class="max-w-[1140px] mx-auto px-4 md:px-8 lg:px-20">
      <h1 class="text-3xl md:text-5xl font-extrabold leading-tight tracking-tight mb-4">Contacto</h1>
      <p class="text-lg text-cream/65 max-w-2xl leading-relaxed">Escribinos para consultas técnicas, proyectos o propuestas de colaboración.</p>
    </div>
  </section>

  <!-- CONTENIDO PRINCIPAL -->
  <section class="py-16 md:py-24">
    <div class="max-w-[1140px] mx-auto px-4 md:px-8 lg:px-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <!-- FORMULARIO -->
        <div>
          <h2 class="text-2xl font-bold tracking-tight mb-8">Déjanos un mensaje</h2>
          <form class="space-y-6">
            <!-- Nombre -->
            <div>
              <label for="nombre" class="block text-sm font-semibold text-slate-dg mb-2">Nombre</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder="Tu nombre"
                class="w-full px-4 py-3 rounded border border-slate-dg/20 focus:border-arena focus:outline-none focus:ring-2 focus:ring-arena/10 transition-colors"
              />
            </div>

            <!-- Empresa -->
            <div>
              <label for="empresa" class="block text-sm font-semibold text-slate-dg mb-2">Empresa</label>
              <input
                type="text"
                id="empresa"
                name="empresa"
                placeholder="Nombre de tu empresa"
                class="w-full px-4 py-3 rounded border border-slate-dg/20 focus:border-arena focus:outline-none focus:ring-2 focus:ring-arena/10 transition-colors"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-semibold text-slate-dg mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="tu@email.com"
                class="w-full px-4 py-3 rounded border border-slate-dg/20 focus:border-arena focus:outline-none focus:ring-2 focus:ring-arena/10 transition-colors"
              />
            </div>

            <!-- Mensaje -->
            <div>
              <label for="mensaje" class="block text-sm font-semibold text-slate-dg mb-2">Mensaje</label>
              <textarea
                id="mensaje"
                name="mensaje"
                placeholder="Cuéntanos sobre tu proyecto o consulta"
                rows="6"
                class="w-full px-4 py-3 rounded border border-slate-dg/20 focus:border-arena focus:outline-none focus:ring-2 focus:ring-arena/10 transition-colors resize-none"
              ></textarea>
            </div>

            <!-- Botón -->
            <button
              type="submit"
              class="w-full bg-slate-dg text-cream px-6 py-3 rounded font-semibold text-sm hover:bg-slate-light transition-colors"
            >
              Enviar mensaje
            </button>
          </form>
        </div>

        <!-- INFORMACIÓN DE CONTACTO -->
        <div>
          <h2 class="text-2xl font-bold tracking-tight mb-8">Información de contacto</h2>

          <!-- Email -->
          <div class="mb-10 pb-10 border-b border-slate-dg/10">
            <h3 class="text-sm font-semibold uppercase tracking-[2px] text-gray-neutral mb-3">Email</h3>
            <a
              href="mailto:info@dgingenieriasrl.com"
              class="text-lg text-slate-dg hover:text-arena transition-colors font-medium"
            >
              info@dgingenieriasrl.com
            </a>
            <p class="text-sm text-gray-neutral mt-2">Respuesta en horario laboral</p>
          </div>

          <!-- Teléfono -->
          <div class="mb-10 pb-10 border-b border-slate-dg/10">
            <h3 class="text-sm font-semibold uppercase tracking-[2px] text-gray-neutral mb-3">Teléfono</h3>
            <a
              href="tel:+595981815180"
              class="text-lg text-slate-dg hover:text-arena transition-colors font-medium"
            >
              +595 981 815 180
            </a>
            <p class="text-sm text-gray-neutral mt-2">Lunes a viernes, 8:30 AM a 18:00 PM (PYT)</p>
          </div>

          <!-- Ubicación -->
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-[2px] text-gray-neutral mb-3">Ubicación</h3>
            <p class="text-lg font-medium text-slate-dg mb-1">Asunción</p>
            <p class="text-sm text-gray-neutral">Paraguay</p>
          </div>

          <!-- Información adicional -->
          <div class="mt-12 p-6 rounded-lg bg-cream-deep border border-slate-dg/10">
            <h3 class="font-semibold text-slate-dg mb-3">¿En qué podemos ayudarte?</h3>
            <ul class="space-y-2 text-sm text-slate-dg/80">
              <li class="flex items-start gap-2">
                <span class="text-arena mt-1">▪</span>
                <span>Consulta técnica en infraestructura</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-arena mt-1">▪</span>
                <span>Desarrollo de proyectos</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-arena mt-1">▪</span>
                <span>Fiscalización de obras</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-arena mt-1">▪</span>
                <span>Propuestas de colaboración</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FOOTER -->
  <section class="bg-slate-dg text-cream text-center py-16 md:py-20">
    <div class="max-w-[1140px] mx-auto px-4 md:px-8 lg:px-20">
      <h2 class="text-2xl md:text-3xl font-bold mb-3">¿Tienes urgencia?</h2>
      <p class="text-base text-cream/50 mb-8 max-w-[440px] mx-auto">Llámanos directamente al número de teléfono indicado arriba.</p>
    </div>
  </section>

</Base>
